APP_NAME="Ultralink Monitor"
APP_ENV=development
API_V1_PREFIX=/api/v1
APP_DEBUG=true

DATABASE_URL=postgresql+psycopg://ultralink:ultralink@localhost:5432/ultralink_monitor
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

FIRST_SUPERUSER_EMAIL=admin@ultralink.local
FIRST_SUPERUSER_PASSWORD=admin123
FIRST_SUPERUSER_NAME="Ultralink Admin"

THINGSBOARD_BASE_URL=http://localhost:8080
THINGSBOARD_USERNAME=tenant@thingsboard.org
THINGSBOARD_PASSWORD=tenant

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
