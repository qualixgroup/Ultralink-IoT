APP_NAME="Ultralink Monitor"
APP_ENV=production
API_V1_PREFIX=/api/v1
APP_DEBUG=false

DATABASE_URL=postgresql+psycopg://ultralink:change-me@postgres:5432/ultralink_monitor
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

FIRST_SUPERUSER_EMAIL=admin@ultralink.io
FIRST_SUPERUSER_PASSWORD=replace-with-a-strong-password
FIRST_SUPERUSER_NAME="Ultralink Admin"

CORS_ORIGINS=https://app.ultralinkia.site

THINGSBOARD_BASE_URL=https://monitor.ultralinkia.site
THINGSBOARD_USERNAME=tenant@thingsboard.org
THINGSBOARD_PASSWORD=replace-with-thingsboard-password

MQTT_HOST=thingsboard
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
